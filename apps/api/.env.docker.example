# Docker Desktop containers cannot use localhost to reach services running on your Mac.
# Use host.docker.internal instead.

# Replace this with the actual Postgres TCP connection string that works from your Mac.
# If your local Postgres requires a password, use:
# DATABASE_URL=postgresql://your-postgres-user:your-postgres-password@host.docker.internal:5432/yukiguni
DATABASE_URL=postgresql://your-postgres-user@host.docker.internal:5432/yukiguni
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://yukiguni.pages.dev

R2_BUCKET_NAME=yukiguni-dev
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

REDIS_URL=redis://host.docker.internal:6379/0
RQ_QUEUE_NAME=analysis-jobs
